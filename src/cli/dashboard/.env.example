# Analytics (same IDs as agentos.sh, shared under one property)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_CLARITY_PROJECT_ID=your-clarity-id

# Living-colony grid viz — defaults on. Set VITE_NEW_GRID=0 to opt back
# to the legacy ColonyPanel tile grid. Baked into the bundle at vite
# build time, so a rebuild is needed for the value to take effect.
# VITE_NEW_GRID=0
