{
  "id": "corporate-quarterly",
  "version": "1.0.0",
  "engineArchetype": "closed_turn_based_settlement",

  "labels": {
    "name": "Q-Scope Corp",
    "shortName": "corp",
    "populationNoun": "employees",
    "settlementNoun": "company",
    "currency": "USD",
    "eventNoun": "decisions",
    "eventNounSingular": "decision",
    "timeUnitNoun": "quarter",
    "timeUnitNounPlural": "quarters"
  },

  "theme": {
    "primaryColor": "#3b82f6",
    "accentColor": "#60a5fa",
    "cssVariables": {
      "--bg-primary": "#0b1220",
      "--bg-secondary": "#111a2c",
      "--text-primary": "#e0e7ff",
      "--accent": "#3b82f6"
    }
  },

  "setup": {
    "defaultTurns": 12,
    "defaultSeed": 1,
    "defaultStartTime": 1,
    "defaultTimePerTurn": 1,
    "defaultPopulation": 40,
    "configurableSections": ["leaders", "personnel", "resources", "departments", "events", "models"]
  },

  "departments": [
    { "id": "sales",       "label": "Sales",       "role": "VP of Sales",        "icon": "💼", "defaultModel": "gpt-5.4-mini", "instructions": "You are the VP of Sales. You analyze pipeline coverage, ACV trends, close rates, sales cycle length, and territory productivity. You argue for commission structure and GTM bets that move bookings this quarter while protecting next-quarter pipeline." },
    { "id": "engineering", "label": "Engineering", "role": "VP of Engineering",  "icon": "🛠️",  "defaultModel": "gpt-5.4-mini", "instructions": "You are the VP of Engineering. You analyze feature delivery, quality debt, incident load, hiring pipeline, and tooling spend. You flag when a commit deadline forces a cut against quality or headcount." },
    { "id": "finance",     "label": "Finance",     "role": "CFO",                "icon": "📊", "defaultModel": "gpt-5.4-mini", "instructions": "You are the CFO. You analyze runway, burn, gross margin, unit economics, working capital, and scenarios for the next 4 quarters. Every decision goes through your runway projection before you sign off." },
    { "id": "hr",          "label": "People",      "role": "Chief People Officer","icon": "🧑‍🤝‍🧑", "defaultModel": "gpt-5.4-mini", "instructions": "You are the Chief People Officer. You analyze retention risk, employee engagement, compensation bands, manager load, and culture signal. Every headcount move is weighed against burnout risk and attrition forecast." },
    { "id": "operations",  "label": "Operations",  "role": "COO",                "icon": "🏭", "defaultModel": "gpt-5.4-mini", "instructions": "You are the COO. You analyze cross-functional throughput, vendor risk, contract exposure, operational efficiency, and the gap between plan and reality across every org. You push back when strategy ignores operating constraints." }
  ],

  "metrics": [
    { "id": "population",  "label": "Employees",   "source": "metrics.population",  "format": "number" },
    { "id": "morale",      "label": "Engagement",  "source": "metrics.morale",      "format": "percent" },
    { "id": "revenueArr",  "label": "ARR",         "source": "metrics.revenueArr",  "format": "number" },
    { "id": "burnRate",    "label": "Burn",        "source": "metrics.burnRate",    "format": "number" },
    { "id": "runwayMonths","label": "Runway",      "source": "metrics.runwayMonths","format": "number" },
    { "id": "marketShare", "label": "Market Share","source": "metrics.marketShare", "format": "percent" }
  ],

  "events": [
    { "id": "crisis",     "label": "Crisis",     "icon": "🚨", "color": "#ef4444" },
    { "id": "decision",   "label": "Decision",   "icon": "🧭", "color": "#f59e0b" },
    { "id": "launch",     "label": "Launch",     "icon": "🚀", "color": "#22c55e" },
    { "id": "departure",  "label": "Departure",  "icon": "👋", "color": "#6b7280" },
    { "id": "hire",       "label": "Hire",       "icon": "🎯", "color": "#3b82f6" },
    { "id": "tool_forge", "label": "Tool Forged","icon": "🔧", "color": "#8b5cf6" },
    { "id": "system",     "label": "System",     "icon": "⚙️", "color": "#64748b" }
  ],

  "effects": {
    "market":        { "revenueArr": 500000,  "marketShare": 0.01,  "morale":  0.03 },
    "product":       { "revenueArr": 300000,  "marketShare": 0.015, "burnRate": -20000 },
    "financial":     { "runwayMonths": 2,     "burnRate": -40000,   "morale": -0.02 },
    "organizational":{ "morale": 0.08,        "population": 3 },
    "operational":   { "burnRate": -15000,    "morale": 0.02 },
    "competitive":   { "marketShare": -0.02,  "morale": -0.05,      "revenueArr": -200000 }
  },

  "ui": {
    "headerMetrics": [
      { "id": "population",   "format": "number" },
      { "id": "morale",       "format": "percent" },
      { "id": "revenueArr",   "format": "number" },
      { "id": "burnRate",     "format": "number" },
      { "id": "runwayMonths", "format": "number" },
      { "id": "marketShare",  "format": "percent" }
    ],
    "tooltipFields": ["tenureQuarters", "psychScore", "performanceRating"],
    "reportSections": ["crisis", "departments", "decision", "outcome", "quotes"],
    "departmentIcons": { "sales": "💼", "engineering": "🛠️", "finance": "📊", "hr": "🧑‍🤝‍🧑", "operations": "🏭" },
    "setupSections": ["leaders", "personnel", "resources", "departments", "events", "models"]
  },

  "policies": {
    "toolForging":    { "enabled": true, "requiredPerDepartment": false },
    "liveSearch":     { "enabled": false, "mode": "off" },
    "bulletin":       { "enabled": true },
    "characterChat":  { "enabled": true },
    "sandbox":        { "timeoutMs": 10000, "memoryMB": 128 }
  },

  "presets": [
    {
      "id": "default",
      "label": "Growth vs Discipline",
      "leaders": [
        {
          "name": "Priya Kapoor",
          "archetype": "The Growth CEO",
          "hexaco": { "openness": 0.90, "conscientiousness": 0.45, "extraversion": 0.85, "agreeableness": 0.55, "emotionality": 0.30, "honestyHumility": 0.60 },
          "instructions": "You are Priya Kapoor, 'The Growth CEO.' You lead by bold category bets. You will spend to win a market before you have product-market fit on paper. You trust fast learning over cautious modelling. Your HEXACO profile drives your leadership."
        },
        {
          "name": "Marcus Reinhardt",
          "archetype": "The Discipline CEO",
          "hexaco": { "openness": 0.40, "conscientiousness": 0.95, "extraversion": 0.45, "agreeableness": 0.65, "emotionality": 0.55, "honestyHumility": 0.85 },
          "instructions": "You are Marcus Reinhardt, 'The Discipline CEO.' You lead by unit economics and clean books. You will say no to a tempting market if the payback period is wrong. You think capital efficiency is the durable competitive advantage. Your HEXACO profile drives your leadership."
        }
      ]
    }
  ],

  "world": {
    "metrics": {
      "population":    { "id": "population",    "label": "Employees",   "unit": "people", "type": "number", "initial": 40,     "min": 0,   "category": "metric" },
      "morale":        { "id": "morale",        "label": "Engagement",  "unit": "%",      "type": "number", "initial": 0.72,   "min": 0,   "max": 1,   "category": "metric" },
      "revenueArr":    { "id": "revenueArr",    "label": "ARR",         "unit": "USD",    "type": "number", "initial": 6000000, "min": 0,   "category": "metric" },
      "burnRate":      { "id": "burnRate",      "label": "Burn",        "unit": "USD/mo", "type": "number", "initial": 850000, "min": 0,   "category": "metric" },
      "runwayMonths":  { "id": "runwayMonths",  "label": "Runway",      "unit": "months", "type": "number", "initial": 14,     "min": 0,   "category": "metric" },
      "marketShare":   { "id": "marketShare",   "label": "Market Share","unit": "%",      "type": "number", "initial": 0.08,   "min": 0,   "max": 1,   "category": "metric" }
    },
    "capacities": {
      "hiringCapacity":  { "id": "hiringCapacity",  "label": "Hiring Capacity", "unit": "hires/qtr", "type": "number", "initial": 8,  "category": "capacity" },
      "deliveryCapacity":{ "id": "deliveryCapacity","label": "Delivery Capacity","unit": "initiatives/qtr","type": "number", "initial": 6,  "category": "capacity" }
    },
    "statuses": {
      "fundingRound": { "id": "fundingRound", "label": "Funding Round", "unit": "", "type": "string", "initial": "series-b", "category": "status" }
    },
    "politics": {
      "boardConfidence":  { "id": "boardConfidence",  "label": "Board Confidence",  "unit": "%", "type": "number", "initial": 75, "min": 0, "max": 100, "category": "politic" },
      "investorPressure": { "id": "investorPressure", "label": "Investor Pressure", "unit": "%", "type": "number", "initial": 40, "min": 0, "max": 100, "category": "politic" }
    },
    "environment": {
      "marketGrowthPct":   { "id": "marketGrowthPct",   "label": "Market Growth", "unit": "%", "type": "number", "initial": 25, "category": "environment" },
      "competitorCount":   { "id": "competitorCount",   "label": "Competitors",    "unit": "firms", "type": "number", "initial": 8, "category": "environment" },
      "macroRateBasisPts": { "id": "macroRateBasisPts", "label": "Fed Rate (bps)", "unit": "bps", "type": "number", "initial": 475, "category": "environment" }
    }
  },

  "knowledge": {
    "topics": {},
    "categoryMapping": {}
  },

  "names": {
    "first": ["Priya", "Marcus", "Amina", "Leo", "Haruki", "Sofia", "Elena", "Kwame", "Maya", "Dmitri", "Isla", "Theo", "Chiara", "Arjun", "Yara", "Rune", "Beatriz", "Kenji", "Freya", "Nikolai"],
    "last":  ["Kapoor", "Reinhardt", "Okafor", "Alvarez", "Tanaka", "Rossi", "Nowak", "Mensah", "Patel", "Volkov", "Connor", "Kaufman", "Moretti", "Singh", "Haddad", "Berg", "Oliveira", "Yamamoto", "Lindqvist", "Petrov"],
    "child": []
  }
}
