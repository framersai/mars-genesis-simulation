# Mars Genesis Simulation
# Copy to .env and fill in your keys

# === LLM Providers (at least one required) ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# === Research & Citations (all optional, more = better) ===
# Each provider adds search coverage. Cohere reranks results by relevance.
# With all 4, department agents get richer scientific citations.

# Google search via Serper (most general coverage)
SERPER_API_KEY=

# AI-optimized search with content extraction
TAVILY_API_KEY=

# Web scraping + search with markdown extraction
FIRECRAWL_API_KEY=

# Neural reranking - reorders search results by relevance to the query
# Uses Cohere rerank-v3.5 model. Dramatically improves citation quality.
COHERE_API_KEY=

# === Server ===
PORT=3456

# === Rate Limiting ===
# Max simulations per IP per day. 0 = unlimited (local dev). Default: 3.
# Set to 3 for production to prevent API cost abuse.
RATE_LIMIT=3
